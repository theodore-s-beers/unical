{
  "name": "unical",
  "version": "0.1.0",
  "description": "Date conversion library supporting several historical and modern calendars",
  "keywords": [
    "calendar",
    "conversion",
    "date",
    "gregorian",
    "julian",
    "hebrew",
    "islamic",
    "persian",
    "hijri"
  ],
  "homepage": "https://github.com/theodore-s-beers/unical#readme",
  "bugs": {
    "url": "https://github.com/theodore-s-beers/unical/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theodore-s-beers/unical.git"
  },
  "license": "MIT",
  "author": "Theo Beers",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "prepare": "npm run build",
    "test": "deno test index.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/recommended": "^1.0.13",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.56.1"
  }
}
