{
  "name": "unical",
  "version": "0.1.0",
  "description": "Date conversion library supporting several historical and modern calendars",
  "keywords": [
    "calendar",
    "conversion",
    "date",
    "gregorian",
    "hebrew",
    "hijri",
    "islamic",
    "julian",
    "persian"
  ],
  "homepage": "https://github.com/theodore-s-beers/unical#readme",
  "bugs": {
    "url": "https://github.com/theodore-s-beers/unical/issues"
  },
  "license": "MIT",
  "author": "Theo Beers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theodore-s-beers/unical.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "format": "oxfmt",
    "knip": "knip",
    "lint": "oxfmt --check && oxlint",
    "prepare": "tsc",
    "test": "deno test index.test.ts"
  },
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.13",
    "@types/node": "^25.5.0",
    "knip": "^6.1.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2"
  }
}
